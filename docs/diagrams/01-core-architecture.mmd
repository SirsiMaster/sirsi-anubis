%% DIAGRAM 01: Full system overview — all deities, data flows, product tiers
%% This is the "hero" diagram. Equivalent to siddsachar's "Core Agent Architecture"
%%
%% Layout: User at top, CLI in center, deities in two clusters (Code Gods left,
%% Machine Gods right), Token Intelligence pipeline at bottom, Fleet tier below.

graph TB
    %% ── User Layer ──
    USER["👤 User / Developer"]
    CLI["sirsi CLI<br/>Cobra command framework<br/>Gold + black terminal UI"]
    MCP["MCP Server<br/>JSON-RPC 2.0 stdio<br/>Claude · Cursor · Windsurf"]

    USER -->|"commands"| CLI
    USER -->|"AI tool calls"| MCP

    %% ── Deity Hierarchy ──
    subgraph HORUS["𓂀 Horus — Local Workstation Lord (Free Tier)"]
        direction TB

        subgraph CODE_GODS["Code Gods — Governance & Knowledge"]
            THOTH["𓁟 Thoth<br/>Session Memory<br/>memory.yaml · journal.md · artifacts/"]
            MAAT["𓆄 Ma'at<br/>Quality Gate<br/>Coverage · lint · canon · Feather Weight"]
            ISIS["𓁐 Isis<br/>Health & Remediation<br/>Doctor · network · guard · auto-fix"]
            SESHAT["𓁆 Seshat<br/>Knowledge Bridge<br/>Ingestion · export · Gemini Bridge"]
        end

        subgraph MACHINE_GODS["Machine Gods — Infrastructure & OS"]
            ANUBIS["𓃣 Anubis<br/>Hygiene Engine<br/>81 scan rules · ghost detection · dedup"]
            SEBA["𓇽 Seba<br/>Infra & Hardware<br/>Topology · GPU/ANE/CUDA · fleet discovery"]
            OSIRIS["𓁹 Osiris<br/>Snapshot Keeper<br/>Checkpoints · risk assessment · state preservation"]
        end

        subgraph TOKEN_INTEL["Token Intelligence Pipeline"]
            RTK["⚡ RTK<br/>Output Filter<br/>-60-90% token reduction"]
            VAULT["🏛️ Vault<br/>Context Sandbox<br/>SQLite FTS5 · BM25 code search"]
            HORUS_GRAPH["𓂀 Horus Code Graph<br/>Go AST symbols<br/>8-49x file reduction"]
        end

        RTK -->|"filtered output"| VAULT
        VAULT -->|"structural queries"| HORUS_GRAPH
    end

    subgraph RA["𓇶 Ra — Fleet Lord (Enterprise Tier)"]
        SCARAB["🪲 Scarab<br/>Fleet Sweep<br/>VLANs · subnets · domains"]
        FLEET_NET["𓁯 Net (Fleet)<br/>Cross-endpoint alignment<br/>Drift detection"]
        RA_DASH["Ra Dashboard<br/>Fleet view · aggregated reports"]
    end

    %% ── Net sits above both ──
    NET["𓁯 Net — The Scope Weaver<br/>Development plan · ADRs · canon alignment<br/>🧶 The Loom of Intent"]

    %% ── Communication Bus ──
    STELE["𓊖 Stele — The Ledger<br/>Append-only hash-chained event bus<br/>~/.config/ra/stele.jsonl"]

    %% ── Connections ──
    CLI --> HORUS
    MCP --> HORUS

    NET -->|"plan & scope"| CODE_GODS
    NET -->|"plan & scope"| MACHINE_GODS

    ANUBIS -->|"scan findings"| STELE
    MAAT -->|"governance scores"| STELE
    ISIS -->|"health alerts"| STELE
    THOTH -->|"memory snapshots"| STELE
    SEBA -->|"platform profile"| STELE
    OSIRIS -->|"checkpoint status"| STELE

    STELE -->|"WorkstationReport"| RA
    HORUS -->|"HTTP POST"| RA

    %% ── Styling notes (for renderer) ──
    %% HORUS box: emerald border (#10B981)
    %% RA box: gold border (#C8A951)
    %% NET: gold accent, sits between RA and HORUS
    %% STELE: dashed border (infrastructure, not a deity)
    %% TOKEN_INTEL: emerald accent
    %% CODE_GODS: gold left border
    %% MACHINE_GODS: emerald left border
