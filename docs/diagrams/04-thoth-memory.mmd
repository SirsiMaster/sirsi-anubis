%% DIAGRAM 04: Thoth's three-layer persistent memory system
%% THIS IS THE PRIORITY DIAGRAM — direct name competitor. Must be better than theirs.
%%
%% Their Thoth has: knowledge graph, FAISS semantic recall, 67 typed relations,
%% wiki vault, dream cycle, document extraction.
%%
%% Our Thoth has: memory.yaml (structured state), journal.md (decision history),
%% artifacts/ (deep-dive docs), MCP server, context compression, session persistence.
%% Different architecture — ours is compression-first, theirs is graph-first.

graph TB
    %% ── Input Sources ──
    subgraph INPUTS["1. Input Sources"]
        GIT["Git History<br/>commits · diffs · blame"]
        CODE["Source Code<br/>Go packages · tests · configs"]
        DECISIONS["Architectural Decisions<br/>ADRs · CLAUDE.md · rules"]
        SESSION["Session Activity<br/>commands run · files changed"]
    end

    %% ── Sync Engine ──
    subgraph SYNC["2. Thoth Sync Engine"]
        direction TB
        IDENTITY["Phase 1: Identity Fields<br/>Project name · version · language<br/>module count · test count · LOC"]
        JOURNAL["Phase 2: Journal from Git<br/>Recent commits → session entries<br/>Decision rationale extraction"]
        COMPRESS["Phase 3: Compression<br/>22,958 lines → 297 lines<br/>~98% token reduction"]
    end

    %% ── Three-Layer Memory ──
    subgraph MEMORY["3. Persistent Memory (~/.thoth/)"]
        direction TB
        LAYER1["<b>Layer 1: memory.yaml</b><br/>Structured YAML · ~50 lines<br/>Identity · architecture · conventions · state<br/>Full project context in < 2K tokens"]
        LAYER2["<b>Layer 2: journal.md</b><br/>Running session log<br/>Decisions · progress · blockers<br/>AI reads latest entry only"]
        LAYER3["<b>Layer 3: artifacts/</b><br/>Deep-dive documents<br/>Architecture diagrams · benchmarks · case studies<br/>Referenced on demand, not every session"]
    end

    %% ── MCP Server ──
    subgraph MCP_SERVER["4. MCP Server (JSON-RPC 2.0)"]
        direction TB
        TOOL_MEMORY["thoth_read_memory<br/>Returns memory.yaml"]
        TOOL_JOURNAL["thoth_read_journal<br/>Returns latest journal entry"]
        TOOL_ARTIFACT["thoth_read_artifact<br/>Returns specific deep-dive doc"]
        TOOL_SYNC["thoth_sync<br/>Triggers full re-sync"]
        TOOL_STATUS["thoth_status<br/>Memory freshness + token stats"]
    end

    %% ── Consumers ──
    subgraph CONSUMERS["5. AI Session Consumers"]
        CLAUDE["Claude Code<br/>CLI + Desktop"]
        CURSOR["Cursor<br/>IDE integration"]
        WINDSURF["Windsurf<br/>IDE integration"]
        ANY_MCP["Any MCP Client<br/>stdio protocol"]
    end

    %% ── Flows ──
    INPUTS -->|"raw project state"| SYNC
    SYNC -->|"compressed output"| MEMORY
    MEMORY -->|"served via"| MCP_SERVER
    MCP_SERVER -->|"context on demand"| CONSUMERS

    %% ── Key Metrics (callout boxes) ──
    %% Before Thoth: 5-10 min re-reading old files, 100K tokens burned, $0.30/session
    %% After Thoth:  200ms memory load, 2K tokens, $0.006/session
    %% Reduction: 98% context tokens, 50x cost reduction, 200ms cold start

    %% ── Rendering notes ──
    %% Top-to-bottom flow (data pipeline)
    %% MEMORY is the central/largest section with 3 stacked layers
    %% Layer 1 (memory.yaml) is gold-bordered — this is the star
    %% Layer 2 (journal) is emerald-bordered
    %% Layer 3 (artifacts) is dim-bordered (accessed least often)
    %% MCP tools listed as mono-font items in their box
    %% Before/After callout at bottom showing the 98% reduction
