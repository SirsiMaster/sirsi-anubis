%% DIAGRAM 07: The deity-based governance loop
%% Net → Machine Gods execute → Ma'at weighs → Isis heals → Thoth records → Net re-aligns
%% This is the "operating system" of Pantheon — how deities coordinate

graph LR
    %% ── The Cycle ──
    NET["𓁯 <b>1. Net Publishes the Plan</b><br/>Scope definition · ADR alignment<br/>🧶 Loom of Intent weaves instructions"]

    EXECUTE["𓃣 <b>2. Machine Gods Execute</b><br/>Anubis scans · Seba maps<br/>Osiris checkpoints · Isis guards"]

    MAAT["𓆄 <b>3. Ma'at Weighs</b><br/>Coverage audit · lint check<br/>Canon compliance · Feather Weight score<br/>Pass threshold: 85/100"]

    ISIS["𓁐 <b>4. Isis Heals the Drift</b><br/>Auto-fix lint violations<br/>Resolve vet warnings<br/>Patch canon drift · network remediation"]

    THOTH["𓁟 <b>5. Thoth Records</b><br/>Update memory.yaml<br/>Append journal entry<br/>Archive artifacts if significant"]

    REALIGN["𓁯 <b>6. Net Re-Aligns the Weave</b><br/>Compare current state to plan<br/>Detect scope drift<br/>Issue corrective weave"]

    %% ── Cycle Flow ──
    NET -->|"plan & scope"| EXECUTE
    EXECUTE -->|"findings & artifacts"| MAAT
    MAAT -->|"failures & drift"| ISIS
    MAAT -->|"pass (score >= 85)"| THOTH
    ISIS -->|"healed state"| THOTH
    THOTH -->|"updated knowledge"| REALIGN
    REALIGN -->|"next iteration"| NET

    %% ── Stele (central bus) ──
    STELE["𓊖 Stele<br/>Every step inscribes an event"]

    NET -.->|"event"| STELE
    EXECUTE -.->|"event"| STELE
    MAAT -.->|"event"| STELE
    ISIS -.->|"event"| STELE
    THOTH -.->|"event"| STELE

    %% ── Rendering notes ──
