%% DIAGRAM 06: Enterprise tier — Ra receiving reports from multiple Horus instances
%% This diagram has NO equivalent in the competitor's project.
%% Shows: workstation → pod → cluster → fleet scaling

graph TB
    %% ── Fleet Nodes ──
    subgraph FLEET["Fleet — N Workstations"]
        direction LR
        subgraph NODE1["Workstation 1"]
            H1["𓂀 Horus"]
            H1_DEITIES["Anubis · Ma'at · Thoth<br/>Isis · Seba · Osiris"]
        end
        subgraph NODE2["Workstation 2"]
            H2["𓂀 Horus"]
            H2_DEITIES["Anubis · Ma'at · Thoth<br/>Isis · Seba · Osiris"]
        end
        subgraph NODE3["Workstation N"]
            H3["𓂀 Horus"]
            H3_DEITIES["Anubis · Ma'at · Thoth<br/>Isis · Seba · Osiris"]
        end
    end

    %% ── Transport ──
    subgraph TRANSPORT["Transport Layer"]
        HTTP["HTTP POST<br/>WorkstationReport JSON"]
        STELE_SYNC["Stele Sync<br/>Event ledger replication"]
    end

    %% ── Ra ──
    subgraph RA["𓇶 Ra — Fleet Lord"]
        direction TB
        INGEST["Ingestion Endpoint<br/>/api/fleet/report<br/>Accepts WorkstationReports"]

        subgraph RA_MODULES["Fleet Modules"]
            SCARAB["🪲 Scarab<br/>Fleet Sweep<br/>VLAN · subnet · domain discovery"]
            FLEET_NET["𓁯 Net (Fleet)<br/>Cross-endpoint alignment<br/>Configuration drift detection"]
            AGG_THOTH["𓁟 Aggregated Thoth<br/>Fleet-wide memory<br/>Cross-machine knowledge"]
            AGG_SESHAT["𓁆 Aggregated Seshat<br/>Fleet-wide knowledge<br/>Shared learnings"]
        end

        subgraph RA_OUTPUTS["Fleet Outputs"]
            DASHBOARD["Ra Dashboard<br/>Fleet health · node status<br/>Drift alerts · compliance"]
            POLICY["Fleet Policy Engine<br/>Enforce rules across all nodes<br/>Audit trails · SLA tracking"]
            REPORTS["Compliance Reports<br/>SOC 2 · HIPAA artifacts<br/>Exportable audit logs"]
        end

        INGEST --> RA_MODULES
        RA_MODULES --> RA_OUTPUTS
    end

    %% ── Connections ──
    H1 -->|"report"| TRANSPORT
    H2 -->|"report"| TRANSPORT
    H3 -->|"report"| TRANSPORT
    TRANSPORT --> INGEST

