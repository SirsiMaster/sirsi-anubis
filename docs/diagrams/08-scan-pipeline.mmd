%% DIAGRAM 08: Anubis scan lifecycle from trigger to cleanup
%% Shows: trigger → scan → findings → policy → judgment → clean/report

graph TB
    %% ── Trigger ──
    subgraph TRIGGER["1. Trigger"]
        CLI_SCAN["sirsi scan<br/>Manual CLI invocation"]
        MCP_SCAN["MCP: scan_workspace<br/>AI tool call"]
        CRON["Scheduled scan<br/>Background interval"]
        PREPUSH["Pre-push hook<br/>𓆄 Ma'at gate"]
    end

    %% ── Scan Engine ──
    subgraph SCAN["2. 𓃣 Anubis Scan Engine"]
        direction TB
        RULES["81 Scan Rules<br/>Each rule: self-contained Go file<br/>Implements ScanRule interface"]

        subgraph DOMAINS["7 Scan Domains"]
            D1["Caches<br/>Homebrew · npm · pip · Go mod"]
            D2["Build Artifacts<br/>Xcode · Gradle · cargo"]
            D3["Orphaned Files<br/>Stale configs · dead symlinks"]
            D4["Ghost Apps<br/>𓂓 Ka: 17 macOS locations<br/>Launch Services · plists · Spotlight"]
            D5["Containers<br/>Docker images · volumes · networks"]
            D6["AI/ML<br/>HuggingFace cache · model artifacts"]
            D7["Duplicates<br/>3-phase dedup: size → partial → full SHA-256"]
        end

        RULES --> DOMAINS
    end

    %% ── Findings ──
    subgraph FINDINGS["3. Findings"]
        REPORT["Finding Report<br/>path · size · domain · severity<br/>reclaimable bytes · confidence"]
        RANK["Semantic Ranking<br/>Sort by impact · group by domain<br/>Surface highest-value items first"]
    end

    %% ── Policy ──
    subgraph POLICY["4. ⚖️ Scales — Policy Engine"]
        RULES_YAML["configs/default_rules.yaml<br/>Per-rule enable/disable"]
        POLICIES_YAML["configs/default_policies.yaml<br/>Severity thresholds · profiles"]
        PROFILES["4 Profiles<br/>General · Developer · AI Engineer · DevOps"]
    end

    %% ── Judgment ──
    subgraph JUDGMENT["5. Judgment"]
        DRYRUN["--dry-run<br/>Report only, no changes<br/><b>ALWAYS available (Rule A1)</b>"]
        CONFIRM["User Confirmation<br/>Interactive approval<br/>Per-finding or bulk"]
        CLEAN["Clean Phase<br/>SHA-256 verified deletion<br/>Protected paths enforced"]
    end

    %% ── Output ──
    subgraph OUTPUT["6. Output"]
        TERMINAL["Terminal<br/>lipgloss styled · gold + black<br/>Progress bar for > 2s ops"]
        JSON["--json<br/>Raw JSON for piping/scripting"]
        STELE_OUT["𓊖 Stele Event<br/>scan.complete · findings.count"]
        HORUS_OUT["𓂀 Horus Report<br/>Aggregated into WorkstationReport"]
    end

    %% ── Flow ──
    TRIGGER -->|"invocation"| SCAN
    SCAN -->|"raw findings"| FINDINGS
    FINDINGS -->|"ranked findings"| POLICY
    POLICY -->|"policy-filtered"| JUDGMENT
    JUDGMENT --> OUTPUT

    %% ── Safety (annotations) ──
    %% Rule A1: NEVER delete without dry-run available
    %% Rule A2: Scan phase is READ-ONLY (no side effects)
    %% Clean phase requires explicit user confirmation
    %% Protected system paths hardcoded in internal/cleaner/safety.go

    %% ── Rendering notes ──
    %% Top-to-bottom flow (pipeline)
