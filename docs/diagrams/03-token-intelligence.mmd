---
title: Token Intelligence Pipeline
subtitle: "Raw output enters. Minimal, structured context exits."
---

%% DIAGRAM 03: The RTK → Vault → Horus pipeline
%% This is unique to Pantheon — the competitor has nothing like it.
%% Shows how raw tool output gets reduced before hitting the AI context window.

graph LR
    %% ── Input ──
    RAW["Raw Tool Output<br/>ANSI codes · repeated lines<br/>blank runs · full file dumps<br/><b>100% of tokens</b>"]

    %% ── Stage 1: RTK ──
    subgraph RTK["⚡ RTK — The Sieve"]
        direction TB
        RTK_ANSI["Strip ANSI escape sequences"]
        RTK_DEDUP["Deduplicate consecutive identical lines"]
        RTK_BLANK["Collapse blank line runs"]
        RTK_TRUNC["Truncate with tail preservation"]
        RTK_ANSI --> RTK_DEDUP --> RTK_BLANK --> RTK_TRUNC
    end

    %% ── Stage 2: Vault ──
    subgraph VAULT["🏛️ Vault — The Keeper"]
        direction TB
        VAULT_STORE["Store large output in SQLite FTS5"]
        VAULT_INDEX["BM25-index source code files"]
        VAULT_QUERY["Return relevant chunks on demand"]
        VAULT_STATS["Track token savings metrics"]
        VAULT_STORE --> VAULT_INDEX --> VAULT_QUERY --> VAULT_STATS
    end

    %% ── Stage 3: Horus ──
    subgraph HORUS["𓂀 Horus — The All-Seeing"]
        direction TB
        HORUS_AST["Parse Go AST (standard library)"]
        HORUS_OUTLINE["Extract declarations only (no bodies)"]
        HORUS_SYMBOLS["Serve structural symbol graph"]
        HORUS_WATCH["Live file watcher (fsnotify)"]
        HORUS_AST --> HORUS_OUTLINE --> HORUS_SYMBOLS
    end

    %% ── Output ──
    CONTEXT["AI Context Window<br/>Minimal, structured, queryable<br/><b>2-10% of original tokens</b>"]

    %% ── Flow ──
    RAW -->|"unfiltered<br/>100%"| RTK
    RTK -->|"filtered<br/>10-40% remains"| VAULT
    VAULT -->|"sandboxed<br/>query on demand"| HORUS
    HORUS -->|"structural outlines<br/>2-10% of original"| CONTEXT

    %% ── MCP Tools (annotations) ──
    %% RTK: filter_output
    %% Vault: vault_store, vault_search, vault_get, vault_stats, code_index, code_search
    %% Horus: code_symbols, code_outline, code_context

    %% ── Metrics (for callout boxes) ──
    %% RTK: 60-90% reduction at source
    %% Vault: 0 tokens used (sandboxed, queryable later)
    %% Horus: 8-49x smaller than full source files
    %% Combined: ~98% context token reduction

    %% ── Rendering notes ──
    %% Left-to-right flow (pipeline)
    %% Each stage is a numbered box (1, 2, 3)
    %% Arrow labels show percentage of tokens remaining
    %% RAW box: red/warning accent (this is the problem)
    %% CONTEXT box: emerald accent (this is the solution)
    %% Between each stage: a metric callout showing reduction factor
