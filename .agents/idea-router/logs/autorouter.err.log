				Foreground(lipgloss.Color("#0F0F0F")).
				Background(Gold).
				Bold(true).
				Padding(0, 1).
				Render(fmt.Sprintf("%d", i+1))
			b.WriteString("  " + keyBadge +
				"  " + body.Bold(true).Render(action.Label) + "\n")
			b.WriteString("       " + dim.Render(action.Desc) + "\n\n")
		}
	}

	return b.String()
}

