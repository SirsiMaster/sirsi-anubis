+		t.Errorf("status output missing 'What's Next' section\noutput:\n%s", combined)
+	}
+	// Must suggest --live for TUI
+	if !strings.Contains(combined, "--live") {
+		t.Errorf("status output missing '--live' suggestion\noutput:\n%s", combined)
+	}
+}
