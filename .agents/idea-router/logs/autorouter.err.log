func (m TUIModel) handleDoneKey(key string) (tea.Model, tea.Cmd) {
	switch key {
	case "esc":
		// Back to tab
		m.mode = viewTabs
		m.outputLines = nil
		m.postRunCmds = nil
		m.recalcViewport()
		return m, nil
	case "up", "pgup":
