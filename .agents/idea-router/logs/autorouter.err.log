// ── History Dedup ───────────────────────────────────────────────────

func TestDeduplicateHistory(t *testing.T) {
	t.Parallel()
	history := []historyEntry{
		{command: "scan"},
		{command: "doctor"},
		{command: "scan"},
	}
	result := deduplicateHistory(history)
	if len(result) != 2 {
		t.Errorf("expected 2 unique commands, got %d: %v", len(result), result)
	}
}

