			IsDir:       pf.IsDir,
			FileCount:   pf.FileCount,
		}
		if pf.LastModified != "" {
			f.LastModified, _ = time.Parse(time.RFC3339, pf.LastModified)
		}
		findings = append(findings, f)
	}

