	r.Submit(DocProposal, "claude", "Prop One", "# Proposal: Prop One\n\nauthor: claude\n\ncontent")
	r.Submit(DocReview, "codex", "Rev One", "# Review: Rev One\n\nreviewer: codex\n\ncontent")
