#!/bin/bash
# 𓂀 Pantheon Pre-Push Gate
# Guarantees CI stays green by running the SAME checks CI runs locally.
# Install: git config core.hooksPath .githooks
# Skip:    git push --no-verify (use sparingly)

set -e

echo ""
echo "  𓇳 Pantheon pre-push gate..."
echo ""

# Detect tag-only pushes (skip Ma'at for speed — tags don't change code)
TAG_ONLY=true
while read local_ref local_sha remote_ref remote_sha; do
    case "$local_ref" in
        refs/tags/*) ;;
        *) TAG_ONLY=false ;;
    esac
done

# 0. Build fresh binary for Ma'at assessment
go build -o ./pantheon ./cmd/pantheon/ 2>/dev/null
if [ "$TAG_ONLY" = "false" ] && [ -x "./pantheon" ]; then
    echo "  𓆄 Ma'at quality assessment..."
    ./pantheon maat --coverage --canon || {
        echo "  ❌ Ma'at assessment failed — quality standards not met"
        exit 1
    }
else
    echo "  ⏭️  Tag push — skipping Ma'at (code unchanged)"
fi

# 1. gofmt — formatting must be canonical
BAD_FMT=$(gofmt -l ./internal/ ./cmd/ 2>/dev/null || true)
if [ -n "$BAD_FMT" ]; then
    echo "  ❌ gofmt — these files need formatting:"
    echo "$BAD_FMT" | sed 's/^/     /'
    echo ""
    echo "  Fix: gofmt -w ./internal/ ./cmd/"
    exit 1
fi

# 2. go vet — static analysis
if ! go vet ./... 2>/dev/null; then
    echo "  ❌ go vet failed"
    exit 1
fi

# 3. golangci-lint — full linter suite (if installed)
LINT_BIN=""
if command -v golangci-lint &>/dev/null; then
    LINT_BIN="golangci-lint"
elif [ -x "$HOME/go/bin/golangci-lint" ]; then
    LINT_BIN="$HOME/go/bin/golangci-lint"
fi

if [ -n "$LINT_BIN" ]; then
    if ! $LINT_BIN run --timeout=2m 2>/dev/null; then
        echo ""
        echo "  ❌ golangci-lint failed — fix errors before pushing"
        exit 1
    fi
else
    echo "  ⚠️  golangci-lint not found — skipping (install for full gate)"
fi

# 4. Build check — both binaries, same as CI
if ! go build ./... 2>/dev/null; then
    echo "  ❌ build failed"
    exit 1
fi

# 5. ──────────────────────────────────────────────────────────────────
#    TEST SUITE — the #1 reason CI goes red
#    Runs the full test suite locally. This is the gate CI uses.
#    Tests with //go:build darwin tags will be skipped on Linux CI,
#    so platform-specific failures can't slip through.
# ──────────────────────────────────────────────────────────────────
echo "  🧪 Running test suite..."
if ! go test ./... -count=1 -timeout 120s 2>/dev/null; then
    echo ""
    echo "  ❌ Tests failed — CI would fail. Fix before pushing."
    echo "  Run: go test -v ./... to see failures"
    exit 1
fi

# 6. IDE / Agent Health Check
echo "  👁️ Checking Agent health..."
if [ -f ".thoth/memory.yaml" ]; then
    if ! grep -q "project: sirsi-pantheon" .thoth/memory.yaml; then
        echo "  ❌ Thoth memory corrupted or mismatched"
        exit 1
    fi
fi

echo "  ✅ Pipeline gate passed — pushing to the Pantheon"
echo ""
