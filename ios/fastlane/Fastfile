default_platform(:ios)

# ─────────────────────────────────────────────
# Pantheon iOS — Fastlane Pipeline
# Build: Go xcframework → xcodegen → archive → TestFlight
# ─────────────────────────────────────────────

platform :ios do
  before_all do
    ensure_git_status_clean unless ENV["CI"]
  end

  # ── Build the Go xcframework via gomobile ──
  desc "Build PantheonCore.xcframework from Go source"
  lane :framework do
    Dir.chdir("..") do
      sh("cd .. && make ios-framework")
    end
    UI.success("PantheonCore.xcframework built")
  end

  # ── Generate Xcode project from project.yml ──
  desc "Regenerate .xcodeproj from project.yml"
  lane :generate do
    sh("cd .. && xcodegen generate")
    UI.success("Xcode project regenerated")
  end

  # ── Build (no signing, verification only) ──
  desc "Build for device (no code signing)"
  lane :build do
    framework
    generate
    xcodebuild(
      project: "Pantheon.xcodeproj",
      scheme: "Pantheon",
      sdk: "iphoneos",
      xcargs: "CODE_SIGNING_ALLOWED=NO -arch arm64",
      build_settings: {
        "DERIVED_DATA_PATH" => "build"
      }
    )
    UI.success("BUILD SUCCEEDED — device binary verified")
  end

  # ── Archive + TestFlight ──
  desc "Archive and upload to TestFlight"
  lane :beta do
    framework
    generate

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "Pantheon.xcodeproj"
    )

    build_app(
      project: "Pantheon.xcodeproj",
      scheme: "Pantheon",
      export_method: "app-store",
      output_directory: "build/archive",
      output_name: "Pantheon.ipa",
      include_bitcode: false,
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: ENV["APP_STORE_CONNECT_APP_ID"],
      changelog: last_git_commit[:message]
    )

    UI.success("Pantheon uploaded to TestFlight")
  end

  # ── Tests (simulator) ──
  desc "Run unit tests on simulator"
  lane :test do
    generate
    run_tests(
      project: "Pantheon.xcodeproj",
      scheme: "Pantheon",
      device: "iPhone 16 Pro",
      clean: true,
      code_coverage: true
    )
  end

  # ── Screenshots (for App Store) ──
  desc "Capture App Store screenshots"
  lane :screenshots do
    generate
    capture_screenshots(
      project: "Pantheon.xcodeproj",
      scheme: "Pantheon",
      output_directory: "fastlane/screenshots",
      clear_previous_screenshots: true,
      devices: [
        "iPhone 16 Pro Max",
        "iPhone SE (3rd generation)",
        "iPad Pro (12.9-inch) (6th generation)"
      ]
    )
  end

  after_all do |lane|
    UI.success("Lane #{lane} completed successfully")
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end
end
